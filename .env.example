# Lead relay for the Vercel serverless functions (api/lead.mjs, api/order.mjs).
# Set these as Environment Variables in the Vercel project
# (Settings → Environment Variables). NEVER commit real values.

# Telegram bot tokens from @BotFather. Split B2B/B2C bots post to the same group.
BOT_TOKEN_B2B=
BOT_TOKEN_B2C=
# Optional single-bot fallback used if the split tokens above are not set:
BOT_TOKEN=

# Target Telegram chat / group id (e.g. -1001234567890):
CHAT_ID=
